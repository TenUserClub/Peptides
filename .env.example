# Copy this file to .env in the repository root for local pipeline runs.
# Never commit .env. Put comments on their own lines, not after values.

# Required for fetching source material
EXA_API_KEY=

# Required for drafting, verification, and editing
OPENAI_API_KEY=
OPENAI_WRITING_MODEL=gpt-4o
OPENAI_HUMANISE_MODEL=gpt-4o-mini
OPENAI_VERIFY_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Optional image generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-image

# Optional Supabase run audit and future data helpers.
# Use the server-side service_role key, never an anon key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Pipeline behavior
SITE_DOMAIN=mypeptide.club
AUTO_PUSH=false

# Public site settings. Add these separately to all five Vercel projects.
# Private API keys above do not belong in Vercel.
PUBLIC_CONTACT_EMAIL=
PUBLIC_CORRECTIONS_EMAIL=
PUBLIC_PLAUSIBLE_DOMAIN=
