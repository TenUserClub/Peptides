# Copy to .env (repo root) and fill in. Never commit .env.
# IMPORTANT: Do NOT put comments on the same line as a value.
#            Put all comments on their own lines starting with #.

# ── Required for fetch stages ──
EXA_API_KEY=

# ── Required for LLM stages ──
OPENAI_API_KEY=

# ── Optional: image generation ──
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-image   # optional override; defaults to gemini-3.1-flash-image

# ── Optional: Supabase database (free tier) ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Site config ──
# Use your Vercel domain, e.g.:
# SITE_DOMAIN=peptide-seo-site.vercel.app
SITE_DOMAIN=
