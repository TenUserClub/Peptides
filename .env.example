# Copy to .env (repo root) and fill in. Never commit .env.
# ── Required for fetch stages ────────────────────────────────
EXA_API_KEY=            # https://exa.ai → dashboard → API keys
# ── Required for rank tracking (stage 11) ────────────────────
DATAFORSEO_LOGIN=       # https://dataforseo.com → API access
DATAFORSEO_PASSWORD=
SITE_DOMAIN=            # your-domain.com (no https://)
# ── Publishing ────────────────────────────────────────────────
# Deploys happen via git push (Vercel auto-builds from GitHub).
# Ensure `git push` works without prompts (SSH key or credential manager).
