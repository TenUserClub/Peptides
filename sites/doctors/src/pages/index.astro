---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { stateName } from '../lib/states';

const all = await getCollection('doctors');
const doctors = all.filter((p) => !p.id.startsWith('_sample'));

const roundups = doctors.filter((p) => p.data.kind === 'roundup');
const profiles = doctors.filter((p) => p.data.kind === 'profile');

const total = doctors.length;
const states = [...new Set(doctors.map((p) => p.data.state))].sort();
const specialties = [...new Set(doctors.map((p) => p.data.specialty))].sort();
---
<Base title="Peptide & GLP-1 Doctors Directory | Find Verified Physicians" description={`Browse ${total} verified physicians and doctor roundups specializing in peptide therapy, GLP-1 treatments, and longevity medicine across the US.`}>
  <section class="hero">
    <p class="eyebrow">NPI-checked clinician research</p>
    <h1>Find the right expertise, without the guesswork.</h1>
    <p>Research physicians, specialists, and independently compiled roundups for peptide therapy, GLP-1 care, hormone optimization, and longevity medicine.</p>
  </section>

  {total === 0 ? (
    <div class="empty-state"><h2>Doctor research is in progress.</h2><p>Profiles and roundups will appear after identity, NPI, and first-party service checks are complete.</p></div>
  ) : (
    <>
      <p class="meta">
        {total} verified listings · {states.length} states · {specialties.length} specialties
      </p>

      <div class="directory-filters" id="doctor-filters">
        <input type="text" id="search-input" placeholder="Search doctors, specialties, or states..." class="search-input" />
        <select id="state-filter" class="filter-select">
          <option value="">All States</option>
          {states.map((s) => <option value={s}>{stateName(s)}</option>)}
        </select>
        <select id="specialty-filter" class="filter-select">
          <option value="">All Specialties</option>
          {specialties.map((s) => <option value={s}>{s}</option>)}
        </select>
        <select id="kind-filter" class="filter-select">
          <option value="">All Types</option>
          <option value="roundup">Roundups</option>
          <option value="profile">Profiles</option>
        </select>
        <button id="clear-filters" class="filter-btn">Clear</button>
      </div>

      <div class="directory-results" id="results-list">
        {doctors.map((p) => (
          <article class="directory-card" data-state={p.data.state} data-specialty={p.data.specialty.toLowerCase()} data-kind={p.data.kind} data-name={(p.data.doctorName || p.data.title).toLowerCase()}>
            <div class="card-main">
              <h3><a href={`/${p.id}/`}>{p.data.title}</a></h3>
              <p class="meta">
                {stateName(p.data.state)}
                {p.data.city && ` · ${p.data.city}`}
                {p.data.specialty && ` · ${p.data.specialty}`}
              </p>
              {p.data.kind === 'roundup' && p.data.methodology && (
                <p class="meta" style="font-style: italic;">{p.data.methodology.slice(0, 120)}...</p>
              )}
              {p.data.kind === 'profile' && p.data.doctorName && (
                <p class="meta">{p.data.doctorName}{p.data.npi && ` · NPI: ${p.data.npi}`}</p>
              )}
            </div>
            <span class={`kind-badge kind-${p.data.kind}`}>{p.data.kind}</span>
            <a href={`/${p.id}/`} class="card-link">View profile →</a>
          </article>
        ))}
      </div>

      <p class="meta" id="results-count">Showing {total} listings</p>
    </>
  )}

  <script>
    (function() {
      const search = document.getElementById('search-input');
      const stateFilter = document.getElementById('state-filter');
      const specialtyFilter = document.getElementById('specialty-filter');
      const kindFilter = document.getElementById('kind-filter');
      const clearBtn = document.getElementById('clear-filters');
      const results = document.getElementById('results-list');
      const count = document.getElementById('results-count');
      const cards = results ? Array.from(results.querySelectorAll('.directory-card')) : [];

      function filter() {
        const q = (search?.value || '').toLowerCase().trim();
        const state = stateFilter?.value || '';
        const specialty = (specialtyFilter?.value || '').toLowerCase();
        const kind = kindFilter?.value || '';

        let visible = 0;
        cards.forEach((card) => {
          const name = card.dataset.name || '';
          const cardState = card.dataset.state || '';
          const cardSpecialty = card.dataset.specialty || '';
          const cardKind = card.dataset.kind || '';

          const matchesSearch = !q || name.includes(q);
          const matchesState = !state || cardState === state;
          const matchesSpecialty = !specialty || cardSpecialty.includes(specialty);
          const matchesKind = !kind || cardKind === kind;

          if (matchesSearch && matchesState && matchesSpecialty && matchesKind) {
            card.style.display = 'flex';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });

        if (count) count.textContent = `Showing ${visible} listing${visible !== 1 ? 's' : ''}`;
      }

      search?.addEventListener('input', filter);
      stateFilter?.addEventListener('change', filter);
      specialtyFilter?.addEventListener('change', filter);
      kindFilter?.addEventListener('change', filter);
      clearBtn?.addEventListener('click', () => {
        if (search) search.value = '';
        if (stateFilter) stateFilter.value = '';
        if (specialtyFilter) specialtyFilter.value = '';
        if (kindFilter) kindFilter.value = '';
        filter();
      });
    })();
  </script>

</Base>
