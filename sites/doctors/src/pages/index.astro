---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { stateName } from '../lib/states';

const doctors = (await getCollection('doctors')).filter((item) => !item.id.startsWith('_sample'));
const states = [...new Set(doctors.map((item) => item.data.state))].sort();
const specialties = [...new Set(doctors.map((item) => item.data.specialty))].sort();
---
<Base title="Peptide Doctors and Experts Directory | Top Peptides List" description={`Research ${doctors.length} NPI-checked clinician profiles and transparent expert roundups across ${states.length} US states.`}>
  <section class="network-hero hero-centered">
    <p class="eyebrow">NPI-checked clinician directory</p>
    <h1>Research peptide doctors without relying on a ranking.</h1>
    <p>Compare public credentials, specialties, practice locations, and documented services. Inclusion is evidence-led, never sold.</p>
    <div class="hero-search"><input id="search-input" type="search" placeholder="Doctor, specialty, state, or city" aria-label="Search doctors and experts" /><button class="cta" type="button" id="search-button">Search profiles</button></div>
    <div class="hero-chips"><button class="hero-chip" type="button" data-quick="GLP-1">GLP-1 care</button><button class="hero-chip" type="button" data-quick="peptide">Peptide services</button><button class="hero-chip" type="button" data-quick="longevity">Longevity</button><a class="hero-chip" href="/faq/">Directory methods</a></div>
  </section>

  <div class="info-strip"><div><strong>{doctors.length} checked entries</strong><span>Profiles and documented roundups</span></div><div><strong>{states.length} states represented</strong><span>Location details linked to public records</span></div><div><strong>{specialties.length} specialties</strong><span>Labels require a supporting source</span></div></div>

  <div class="section-kicker"><div><p class="eyebrow">Directory</p><h2>Look past the headline credentials.</h2></div><p>Use the filters to narrow the field, then confirm current licensure, scope, availability, and fit directly.</p></div>

  {doctors.length === 0 ? <section class="empty-state"><p class="eyebrow">Research in progress</p><h2>Profiles are still in the verification queue.</h2><p>Nothing publishes until identity, NPI data, and the supporting professional source agree.</p><a class="text-link" href="/faq/">See 100 focused directory answers</a></section> : <>
    <div class="directory-filters" id="doctor-filters"><select id="state-filter" class="filter-select"><option value="">Every state</option>{states.map((state) => <option value={state}>{stateName(state)}</option>)}</select><select id="specialty-filter" class="filter-select"><option value="">Every specialty</option>{specialties.map((specialty) => <option value={specialty.toLowerCase()}>{specialty}</option>)}</select><select id="kind-filter" class="filter-select"><option value="">Profiles and roundups</option><option value="profile">Profiles</option><option value="roundup">Roundups</option></select><button id="clear-filters" class="filter-btn" type="button">Clear filters</button></div>
    <div class="directory-results" id="results-list">{doctors.map((item) => <article class="directory-card" data-state={item.data.state} data-specialty={item.data.specialty.toLowerCase()} data-kind={item.data.kind} data-name={`${item.data.doctorName || item.data.title} ${item.data.city || ''} ${item.data.state} ${item.data.specialty}`.toLowerCase()}><div class="card-main"><span class={`kind-badge kind-${item.data.kind}`}>{item.data.kind}</span><h3><a href={`/${item.id}/`}>{item.data.title}</a></h3><p class="meta">{item.data.city ? `${item.data.city}, ` : ''}{stateName(item.data.state)} · {item.data.specialty}{item.data.npi ? ` · NPI ${item.data.npi}` : ''}</p></div><a class="card-link" href={`/${item.id}/`}>View research</a></article>)}</div>
    <p class="meta" id="results-count">Showing {doctors.length} entries</p>
  </>}

  <section class="faq-preview"><div><p class="eyebrow">100 focused doctor answers</p><h2>Credentials are one part of choosing care.</h2><p>Learn how NPI checks, specialties, roundups, appointments, costs, and correction requests work.</p></div><a class="cta" href="/faq/">Open the doctors FAQ</a></section>

  <script>
    const search = document.querySelector('#search-input');
    const searchButton = document.querySelector('#search-button');
    const state = document.querySelector('#state-filter');
    const specialty = document.querySelector('#specialty-filter');
    const kind = document.querySelector('#kind-filter');
    const clear = document.querySelector('#clear-filters');
    const cards = [...document.querySelectorAll('.directory-card')];
    const count = document.querySelector('#results-count');
    const filter = () => { const query = search instanceof HTMLInputElement ? search.value.trim().toLowerCase() : ''; const stateValue = state instanceof HTMLSelectElement ? state.value : ''; const specialtyValue = specialty instanceof HTMLSelectElement ? specialty.value : ''; const kindValue = kind instanceof HTMLSelectElement ? kind.value : ''; let visible = 0; cards.forEach((card) => { if (!(card instanceof HTMLElement)) return; const match = (!query || (card.dataset.name || '').includes(query)) && (!stateValue || card.dataset.state === stateValue) && (!specialtyValue || card.dataset.specialty === specialtyValue) && (!kindValue || card.dataset.kind === kindValue); card.hidden = !match; if (match) visible += 1; }); if (count) count.textContent = `Showing ${visible} entr${visible === 1 ? 'y' : 'ies'}`; };
    search?.addEventListener('input', filter); searchButton?.addEventListener('click', filter); state?.addEventListener('change', filter); specialty?.addEventListener('change', filter); kind?.addEventListener('change', filter);
    clear?.addEventListener('click', () => { if (search instanceof HTMLInputElement) search.value = ''; if (state instanceof HTMLSelectElement) state.value = ''; if (specialty instanceof HTMLSelectElement) specialty.value = ''; if (kind instanceof HTMLSelectElement) kind.value = ''; filter(); });
    document.querySelectorAll('[data-quick]').forEach((button) => button.addEventListener('click', () => { if (search instanceof HTMLInputElement && button instanceof HTMLElement) { search.value = button.dataset.quick || ''; filter(); document.querySelector('#doctor-filters')?.scrollIntoView({ behavior: 'smooth' }); } }));
  </script>
</Base>
