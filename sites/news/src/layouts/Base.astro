---
import { SECTIONS, sectionHref, SITES } from '../lib/sections';

interface Props {
  title: string;
  description: string;
  jsonLd?: Record<string, unknown>;
  showCorrections?: boolean;
  image?: string;
  ogImage?: string;
  currentSection?: string;
}
const { title, description, jsonLd, showCorrections = false, image, ogImage, currentSection = 'News' } = Astro.props;
const canonicalBase = SITES.news;
const siteUrl = canonicalBase;
const canonicalUrl = new URL(Astro.url.pathname, `${canonicalBase}/`).toString();
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : image ? `${siteUrl}${image}` : null;
const correctionsEmail = import.meta.env.PUBLIC_CORRECTIONS_EMAIL;
const analyticsDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
---
<!doctype html>
<html lang="en" data-site="news">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#52745d" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta property="og:site_name" content="Peptides News" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    {analyticsDomain && <script defer data-domain={analyticsDomain} src="https://plausible.io/js/script.js"></script>}
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="header-inner">
        <a href={SITES.news} class="brand" aria-label="Peptides News home">
          <span class="brand-mark" aria-hidden="true"><img src="/brand-mark.svg" alt="" /></span>
          <span><strong>Peptide Atlas</strong><small>Source-led news</small></span>
        </a>
        <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Open navigation" aria-expanded="false" aria-controls="site-nav"><span></span><span></span><span></span></button>
        <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
          {SECTIONS.map((section) => (
            <a href={sectionHref(section)} aria-current={section.label === currentSection ? 'page' : undefined}>{section.label}</a>
          ))}
          <a class="nav-faq" href="/faq/" aria-current={Astro.url.pathname.startsWith('/faq') ? 'page' : undefined}>FAQ</a>
        </nav>
      </div>
    </header>
    <main id="main-content" class="site-main">
      <div class="container"><slot /></div>
      <div class="container trust-footer">
        <div class="disclaimer"><strong>Medical disclaimer</strong><span>This content is for informational purposes only and is not medical advice, diagnosis, or treatment. Peptide therapies vary in regulatory status; several remain under FDA review. Always consult a licensed physician before starting any therapy.</span></div>
        {showCorrections && <div class="corrections"><strong>Corrections</strong><span>Information on this page was compiled from public sources and verified at the time of publication. If something is inaccurate or should be updated or removed, {correctionsEmail ? <a href={`mailto:${correctionsEmail}`}>{correctionsEmail}</a> : <a href={`${SITES.editorial}/corrections/`}>use the corrections page</a>}. We act on requests within 5 business days.</span></div>}
      </div>
    </main>
    <footer class="site-footer"><div class="container footer-inner"><p><strong>Peptide Atlas</strong><br />Evidence-first directories and reporting.</p><nav class="footer-links" aria-label="Editorial information"><a href="/faq/">FAQ</a><a href={`${SITES.editorial}/about/`}>About</a><a href={`${SITES.editorial}/editorial-policy/`}>Editorial policy</a><a href={`${SITES.editorial}/corrections/`}>Corrections</a></nav><p>© {new Date().getFullYear()} Peptides News.<br />No sponsored posts.</p></div></footer>
    <script is:inline>
      (() => {
        const navButton = document.getElementById('nav-toggle');
        const nav = document.getElementById('site-nav');
        navButton?.addEventListener('click', () => {
          const open = nav?.classList.toggle('is-open') || false;
          navButton.setAttribute('aria-expanded', String(open));
          navButton.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
        });
      })();
    </script>
  </body>
</html>
