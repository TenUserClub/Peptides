---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news')).filter((item) => !item.id.startsWith('_sample')).sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const lead = posts[0];
const side = posts.slice(1, 3);
const latest = posts.slice(3);
---
<Base title="Peptides News | Research, FDA and Compounding" description="Fast, source-led reporting on peptide research, FDA actions, compounding policy, drug safety, and industry developments." currentSection="News">
  <div class="news-ticker"><span class="ticker-label">Source watch</span><div class="ticker-track">{posts.length > 0 ? posts.slice(0, 5).map((item) => <a href={`/${item.id}/`}>{item.data.title}</a>) : <><span>FDA actions</span><span>Clinical trials</span><span>Compounding policy</span><span>Safety communications</span></>}</div></div>
  <section class="network-hero">
    <p class="eyebrow">Independent peptide newsroom</p><h1>The update matters. The original source matters more.</h1><p>Follow material developments in research, regulation, compounding, safety, and industry. Reports link back to the document, record, or study behind the headline.</p>
    <div class="hero-chips"><a class="hero-chip" href="#latest">Latest reporting</a><a class="hero-chip" href="/faq/">How coverage works</a><a class="hero-chip" href="https://safepeptides.us/legal/">Legal desk</a></div>
  </section>

  <div class="section-kicker"><div><p class="eyebrow">Top stories</p><h2>What changed, and what did not.</h2></div><p>Dates, scope, and uncertainty stay visible so a fast-moving story does not outrun its evidence.</p></div>
  {posts.length === 0 ? <section class="empty-state"><p class="eyebrow">Newsroom status</p><h2>The first reports are in source review.</h2><p>A story appears only after the primary source, material claims, and context have been checked.</p><a class="text-link" href="/faq/">Read the newsroom FAQ</a></section> : <div class="feature-grid">{lead && <article class="feature-lead"><p class="meta">{lead.data.publishDate.toISOString().slice(0, 10)} · via {lead.data.sourceName}</p><h2><a href={`/${lead.id}/`}>{lead.data.title}</a></h2><a class="text-link" href={`/${lead.id}/`}>Read the report</a></article>}<div class="feature-side">{side.map((item) => <article><p class="meta">{item.data.publishDate.toISOString().slice(0, 10)} · {item.data.sourceName}</p><h3><a href={`/${item.id}/`}>{item.data.title}</a></h3></article>)}</div></div>}

  {latest.length > 0 && <section id="latest"><div class="section-kicker"><div><p class="eyebrow">News feed</p><h2>Latest source-led reports</h2></div></div><div class="story-list">{latest.map((item, index) => <article class="story-row"><span class="story-number">{String(index + 1).padStart(2, '0')}</span><div><p class="meta">{item.data.publishDate.toISOString().slice(0, 10)} · via {item.data.sourceName}</p><h3><a href={`/${item.id}/`}>{item.data.title}</a></h3></div></article>)}</div></section>}

  <section class="faq-preview"><div><p class="eyebrow">500 newsroom answers</p><h2>Read breaking developments with better context.</h2><p>Learn how reports handle primary sources, FDA action, trial results, compounding, corrections, attribution, and submissions.</p></div><a class="cta" href="/faq/">Open the news FAQ</a></section>
</Base>
