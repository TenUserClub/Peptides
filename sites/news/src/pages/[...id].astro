---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('news')).filter((item) => !item.id.startsWith('_sample'));
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;
const sourceClassLabel = {
  government: 'Government document',
  'international-regulator': 'International regulator',
  court: 'Court record',
  'trial-registry': 'Trial registry record',
  research: 'Primary research',
  company: 'Company disclosure',
}[d.sourceClass];

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: d.title,
  datePublished: d.publishDate.toISOString(),
  description: d.description,
  ...(d.image ? { image: `${siteUrl}${d.image}` } : {}),
};
---
<Base title={d.title} description={d.description} jsonLd={jsonLd} image={d.image} ogImage={d.ogImage} currentSection="News">
  <article>
    {d.image && (
      <div class="featured-image">
        <img src={d.image} alt={`Featured image for ${d.title}`} loading="eager" />
      </div>
    )}
    <h1>{d.title}</h1>
    <p class="meta">By {d.author} · Published {d.publishDate.toISOString().slice(0, 10)} · Source dated {d.sourcePublishedDate.toISOString().slice(0, 10)} · {sourceClassLabel} · Primary source: <a href={d.sourceUrl} rel="nofollow">{d.sourceName}</a></p>
    <Content />
  </article>
</Base>
