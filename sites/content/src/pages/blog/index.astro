---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('blog');
const published = all.filter((p) => !p.id.startsWith('_sample')).sort((a, b) => +b.data.publishDate - +a.data.publishDate);

const byCategory: Record<string, typeof published> = {};
for (const post of published) {
  const cat = post.data.category;
  (byCategory[cat] ??= []).push(post);
}
const categories = Object.keys(byCategory).sort();

const totalPosts = published.length;
const totalCategories = categories.length;
---
<Base title="Blog | Peptide Therapy Guides & Resources" description="Educational guides, comparisons, and science-backed resources on peptide therapy, GLP-1 treatments, hormone optimization, and longevity medicine." currentSection="Blog">
  <p class="eyebrow">Evidence-led learning</p>
  <h1>Understand the field, beyond the hype.</h1>
  <p>
    Science-backed guides, comparisons, and educational resources on peptide therapy,
    GLP-1 treatments, hormone optimization, and longevity medicine. Written for patients
    researching their options. No hype, just facts.
  </p>

  {totalPosts === 0 ? (
    <div class="empty-state"><h2>Guides are under editorial review.</h2><p>New guides will appear after their claims and supporting sources have been checked.</p></div>
  ) : (
    <>
      <p class="meta">{totalPosts} guides across {totalCategories} categories</p>
      {categories.map((cat) => (
        <section style="margin-bottom: 2.5rem;">
          <h2 style="text-transform: capitalize; font-size: 1.25rem; margin-bottom: 1rem;">{cat}</h2>
          <div class="card-grid">
            {byCategory[cat].map((p) => (
              <article class="card">
                {p.data.image && <img class="card-image" src={p.data.image} alt="" loading="lazy" />}
                <div class="card-body">
                  <h3><a href={`/blog/${p.id}/`}>{p.data.title}</a></h3>
                  <p class="meta">{p.data.publishDate.toISOString().slice(0, 10)}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </>
  )}

</Base>
