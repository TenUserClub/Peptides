---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('blog')).filter((item) => !item.id.startsWith('_sample')).sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 6);
const legal = (await getCollection('legal')).filter((item) => !item.id.startsWith('_sample')).sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 5);
const hasContent = guides.length + legal.length > 0;
---
<Base title="Safe Peptides | Evidence, Safety and Regulation" description="Source-led peptide guides, safety context, and plain-language legal and regulatory coverage.">
  <section class="network-hero hero-split">
    <div class="hero-copy"><p class="eyebrow">Evidence before enthusiasm</p><h1>Make sense of peptide claims, risks, and rules.</h1><p>Read practical guides alongside primary-source regulatory and legal coverage. Every page separates what is known, what remains uncertain, and what needs professional judgment.</p><div class="hero-actions"><a class="cta" href="/blog/">Explore the guides</a><a class="text-link" href="/legal/">Track laws and regulation</a></div></div>
    <aside class="trust-panel"><p class="eyebrow">The Safe Peptides standard</p><h2>What every published page must show</h2><ul class="trust-list"><li>A named, accessible source</li><li>A visible publication or review date</li><li>Clear regulatory context</li><li>Known limits and uncertainty</li><li>A route to request corrections</li></ul></aside>
  </section>

  <div class="info-strip"><div><strong>Primary sources first</strong><span>Agency documents, court records, trials, and research papers</span></div><div><strong>No treatment sales</strong><span>Education stays separate from commercial recommendations</span></div><div><strong>Human editorial review</strong><span>Claims are checked before publication</span></div></div>

  <div class="section-kicker"><div><p class="eyebrow">Choose your route</p><h2>Learn the medicine. Follow the rules.</h2></div><p>The guide library and legal desk share one source standard, but they answer different questions.</p></div>
  <div class="lane-grid"><article class="lane-card"><span class="tag">Guides</span><h3>Understand evidence and safety</h3><p>Plain-language explainers cover study quality, benefits, risks, costs, comparisons, and questions to take to a clinician.</p><a class="text-link" href="/blog/">Browse educational guides</a></article><article class="lane-card"><span class="tag">Legal desk</span><h3>Track regulation and enforcement</h3><p>Follow FDA actions, compounding policy, court decisions, and state developments with the source document close at hand.</p><a class="text-link" href="/legal/">Browse legal coverage</a></article></div>

  {!hasContent ? <section class="empty-state" style="margin-top: 2rem"><p class="eyebrow">Editorial queue</p><h2>The first pages are undergoing source review.</h2><p>Material publishes only after citations, dates, context, and safety language pass review.</p><a class="text-link" href="/editorial-policy/">Read the complete editorial policy</a></section> : <>
    {guides.length > 0 && <section><div class="section-kicker"><div><p class="eyebrow">Latest guides</p><h2>Read with the evidence in view</h2></div><a class="text-link" href="/blog/">All guides</a></div><div class="card-grid">{guides.map((item) => <article class="card"><div class="card-body"><span class="tag">{item.data.category}</span><h3><a href={`/blog/${item.id}/`}>{item.data.title}</a></h3><p class="meta">Published {item.data.publishDate.toISOString().slice(0, 10)}</p></div></article>)}</div></section>}
    {legal.length > 0 && <section><div class="section-kicker"><div><p class="eyebrow">Policy watch</p><h2>Legal and regulatory developments</h2></div><a class="text-link" href="/legal/">All coverage</a></div><div class="compact-list">{legal.map((item) => <article><p class="meta">{item.data.jurisdiction} · {item.data.publishDate.toISOString().slice(0, 10)}</p><h3><a href={`/legal/${item.id}/`}>{item.data.title}</a></h3></article>)}</div></section>}
  </>}

  <section class="faq-preview"><div><p class="eyebrow">500 source-led answers</p><h2>Build a stronger filter for health claims.</h2><p>Review evidence, FDA status, compounding, legal coverage, citations, safety, corrections, and editorial methods.</p></div><a class="cta" href="/faq/">Open the Safe Peptides FAQ</a></section>
</Base>
