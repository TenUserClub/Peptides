---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const blog = (await getCollection('blog')).filter((post) => !post.id.startsWith('_sample')).sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 6);
const legal = (await getCollection('legal')).filter((post) => !post.id.startsWith('_sample')).sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 5);
const hasPublishedContent = blog.length + legal.length > 0;
---
<Base title="Safe Peptides | Evidence-led Guides & Legal Coverage" description="Evidence-led peptide guides, safety information, and primary-source legal and regulatory coverage." currentSection="Blog">
  <section class="hero journal-hero">
    <p class="eyebrow">Safety, evidence, and regulation</p>
    <h1>Understand peptides beyond the hype.</h1>
    <p>Explore source-led educational guides and plain-English coverage of FDA regulation, compounding policy, enforcement, and legal developments.</p>
    <div class="hero-actions"><a class="cta" href="/blog/">Explore guides</a><a class="text-link" href="/legal/">Read legal coverage</a></div>
  </section>

  {!hasPublishedContent && <section class="empty-state"><p class="eyebrow">Editorial review</p><h2>New material is being prepared.</h2><p>Articles will appear only after their claims and primary sources pass editorial review.</p><a class="text-link" href="/editorial-policy/">Read the editorial policy</a></section>}

  {blog.length > 0 && <section class="editorial-section">
    <div class="section-heading"><div><p class="eyebrow">Learn</p><h2>Evidence-led guides</h2></div><a href="/blog/">All guides</a></div>
    <div class="card-grid">{blog.map((post) => <article class="card"><div class="card-body"><span class="tag">{post.data.category}</span><h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3><p class="meta">{post.data.publishDate.toISOString().slice(0, 10)}</p></div></article>)}</div>
  </section>}

  {legal.length > 0 && <section class="editorial-section">
    <div class="section-heading"><div><p class="eyebrow">Policy watch</p><h2>Laws &amp; legal</h2></div><a href="/legal/">All legal coverage</a></div>
    <div class="compact-list">{legal.map((post) => <article><p class="meta">{post.data.jurisdiction} · {post.data.publishDate.toISOString().slice(0, 10)}</p><h3><a href={`/legal/${post.id}/`}>{post.data.title}</a></h3></article>)}</div>
  </section>}
</Base>
