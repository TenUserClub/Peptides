---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('legal')).filter((item) => !item.id.startsWith('_sample')).sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const federal = posts.filter((p) => p.data.jurisdiction === 'Federal');
const state = posts.filter((p) => p.data.jurisdiction !== 'Federal');
---
<Base title="Peptide Laws & Legal | Peptide Atlas" description="Plain-English coverage of peptide laws, FDA and HHS regulation, compounding policy, and enforcement actions at the federal and state levels." currentSection="Laws & legal">
  <p class="eyebrow">Policy watch</p>
  <h1>Regulation, translated into plain English.</h1>
  <p>How peptides are regulated in the United States: FDA and HHS actions, compounding policy, enforcement, and state rules, reported from primary sources. General information, not legal advice.</p>
  {posts.length === 0 && <div class="empty-state"><h2>Legal coverage is under editorial review.</h2><p>New analysis will appear only when the relevant agency or court source can be linked directly.</p></div>}
  {federal.length > 0 && (
    <section>
      <h2>Federal</h2>
      <ul>
        {federal.map((p) => (
          <li>
            <a href={`/legal/${p.id}/`}>{p.data.title}</a>
            <span class="meta"> · {p.data.publishDate.toISOString().slice(0, 10)} · via {p.data.sourceName}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
  {state.length > 0 && (
    <section>
      <h2>State</h2>
      <ul>
        {state.map((p) => (
          <li>
            <a href={`/legal/${p.id}/`}>{p.data.title}</a>
            <span class="meta"> · {p.data.jurisdiction} · {p.data.publishDate.toISOString().slice(0, 10)} · via {p.data.sourceName}</span>
          </li>
        ))}
      </ul>
    </section>
  )}
</Base>
