{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' https://plausible.io; connect-src 'self' https://plausible.io; img-src 'self' data:; style-src 'self'; font-src 'self'; upgrade-insecure-requests" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "0" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/news",
      "destination": "https://peptidesnews.us/",
      "permanent": true
    },
    {
      "source": "/news/:path*",
      "destination": "https://peptidesnews.us/:path*",
      "permanent": true
    },
    {
      "source": "/updates",
      "destination": "https://peptidesupdates.com/",
      "permanent": true
    },
    {
      "source": "/updates/:path*",
      "destination": "https://peptidesupdates.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "peptides-content.vercel.app" }],
      "destination": "https://safepeptides.us/:path*",
      "permanent": true
    }
  ]
}
