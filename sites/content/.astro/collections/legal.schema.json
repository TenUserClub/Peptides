{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "jurisdiction": {
      "default": "Federal",
      "type": "string"
    },
    "sourceName": {
      "type": "string"
    },
    "sourceUrl": {
      "type": "string",
      "format": "uri"
    },
    "sourceType": {
      "type": "string",
      "const": "primary"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "author": {
      "default": "Peptide Atlas Editorial Team",
      "type": "string"
    },
    "reviewedBy": {
      "type": "string"
    },
    "publishDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "image": {
      "type": "string"
    },
    "ogImage": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "sourceName",
    "sourceUrl",
    "sourceType",
    "publishDate"
  ]
}