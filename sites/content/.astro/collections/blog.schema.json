{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "minItems": 2,
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "author": {
      "default": "Peptide Atlas Editorial Team",
      "type": "string"
    },
    "reviewedBy": {
      "type": "string"
    },
    "publishDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "image": {
      "type": "string"
    },
    "ogImage": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "category",
    "sources",
    "publishDate"
  ]
}