---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('updates')).filter((item) => !item.id.startsWith('_sample')).sort((a, b) => +b.data.publishDate - +a.data.publishDate);
const configuredNewsletterUrl = import.meta.env.PUBLIC_NEWSLETTER_URL;
const newsletterUrl = configuredNewsletterUrl && /^https:\/\//i.test(configuredNewsletterUrl) ? configuredNewsletterUrl : null;
---
<Base title="Peptide Updates | Weekly Evidence and Directory Briefing" description="A weekly briefing of checked clinic listings, doctor profiles, peptide guides, regulation, and source-led news." currentSection="Updates">
  <section class="network-hero hero-split">
    <div class="hero-copy"><p class="eyebrow">Weekly network briefing</p><h1>One calm review of a noisy peptide week.</h1><p>The digest collects eligible clinic, doctor, guide, legal, and news updates after their underlying pages pass review.</p><div class="hero-actions"><a class="cta" href="#editions">Read the editions</a>{newsletterUrl ? <a class="text-link" href={newsletterUrl} rel="noopener noreferrer">Subscribe free by email</a> : <a class="text-link" href="/feed.xml">Follow the free RSS feed</a>}</div></div>
    <aside class="trust-panel"><p class="eyebrow">This week's gate</p><h2>A digest waits until it has enough to say.</h2><ul class="trust-list"><li>At least three eligible network items</li><li>No duplicate or unsupported claims</li><li>Working links to the full source-led pages</li><li>A clear week-of date</li><li>Corrections reflected when material</li></ul></aside>
  </section>

  <div class="info-strip"><div><strong>Five desks, one briefing</strong><span>Clinics, doctors, guides, legal coverage, and news</span></div><div><strong>Weekly, not constant</strong><span>Published when the review threshold is met</span></div><div><strong>Links over summaries</strong><span>Every item sends readers to its complete context</span></div></div>

  <section class="faq-preview"><div><p class="eyebrow">Free delivery</p><h2>Follow new editions without another paid service.</h2><p>The RSS feed works now. A Beehiiv or Substack signup can replace the main button later by setting one public URL, without sending subscriber data through this site.</p></div><div class="hero-actions">{newsletterUrl && <a class="cta" href={newsletterUrl} rel="noopener noreferrer">Subscribe by email</a>}<a class={newsletterUrl ? 'text-link' : 'cta'} href="/feed.xml">Open RSS feed</a></div></section>

  <section id="editions"><div class="section-kicker"><div><p class="eyebrow">Digest archive</p><h2>Review the weeks that cleared the bar.</h2></div><p>Each edition keeps its own date while linked pages retain their original publication and update dates.</p></div>
    {posts.length === 0 ? <div class="empty-state"><p class="eyebrow">Edition zero</p><h2>The first briefing is still being assembled.</h2><p>It will publish after at least three eligible items have passed their separate checks.</p><a class="text-link" href="/faq/">Read 100 focused digest answers</a></div> : <div class="story-list">{posts.map((item, index) => <article class="story-row"><span class="story-number">{String(index + 1).padStart(2, '0')}</span><div><p class="meta">Week of {item.data.weekOf.toISOString().slice(0, 10)}</p><h3><a href={`/${item.id}/`}>{item.data.title}</a></h3></div></article>)}</div>}
  </section>

  <section><div class="section-kicker"><div><p class="eyebrow">Network route map</p><h2>Go directly to the desk you need.</h2></div></div><div class="lane-grid"><article class="lane-card"><span class="tag">Directories</span><h3>Clinics and doctors</h3><p>Research checked public listings with visible methods and correction routes.</p><div class="hero-chips"><a class="hero-chip" href="https://mypeptide.club/">Clinics</a><a class="hero-chip" href="https://toppeptideslist.com/">Doctors</a></div></article><article class="lane-card"><span class="tag">Editorial</span><h3>Guides, legal, and news</h3><p>Read with primary sources, dates, limits, and regulatory context close by.</p><div class="hero-chips"><a class="hero-chip" href="https://safepeptides.us/">Safe Peptides</a><a class="hero-chip" href="https://peptidesnews.us/">News</a></div></article></div></section>

  <section class="faq-preview"><div><p class="eyebrow">100 focused update answers</p><h2>Know what earns a place in the briefing.</h2><p>Review inclusion criteria, clinic and doctor updates, news, guides, dates, links, corrections, and privacy.</p></div><a class="cta" href="/faq/">Open the updates FAQ</a></section>
</Base>
