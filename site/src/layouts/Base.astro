---
interface Props {
  title: string;
  description: string;
  jsonLd?: Record<string, unknown>;
  showCorrections?: boolean;
}
const { title, description, jsonLd, showCorrections = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <style>
      :root { --ink: #1c2333; --muted: #5a6478; --accent: #0f6e5c; --bg: #fdfdfb; --rule: #e6e4dc; }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Georgia, 'Times New Roman', serif; color: var(--ink); background: var(--bg); line-height: 1.65; }
      header, main, footer { max-width: 760px; margin: 0 auto; padding: 0 1.25rem; }
      header { padding-top: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--rule); margin-bottom: 2rem; }
      header a { color: var(--ink); text-decoration: none; font-weight: bold; font-size: 1.15rem; }
      nav a { color: var(--muted); text-decoration: none; margin-right: 1rem; font-size: .9rem; font-family: system-ui, sans-serif; }
      nav a:hover { color: var(--accent); }
      h1 { font-size: 1.9rem; line-height: 1.25; }
      a { color: var(--accent); }
      .meta { color: var(--muted); font-size: .85rem; font-family: system-ui, sans-serif; }
      .disclaimer, .corrections { font-family: system-ui, sans-serif; font-size: .82rem; color: var(--muted); border-top: 1px solid var(--rule); margin-top: 3rem; padding: 1.25rem 0; }
      .cta { background: var(--accent); color: #fff; padding: .7rem 1.2rem; border-radius: 6px; text-decoration: none; display: inline-block; font-family: system-ui, sans-serif; }
      footer { padding-bottom: 2.5rem; }
    </style>
  </head>
  <body>
    <header>
      <a href="/">Peptide Directory &amp; News</a>
      <nav>
        <a href="/clinics/">Clinics</a>
        <a href="/doctors/">Doctors</a>
        <a href="/news/">News</a>
        <a href="/updates/">Weekly updates</a>
      </nav>
    </header>
    <main>
      <slot />
      <div class="disclaimer">
        <strong>Medical disclaimer:</strong> This content is for informational purposes only and is not medical
        advice, diagnosis, or treatment. Peptide therapies vary in regulatory status; several remain under FDA
        review. Always consult a licensed physician before starting any therapy.
      </div>
      {showCorrections && (
        <div class="corrections">
          <strong>Corrections:</strong> Information on this page was compiled from public sources and verified
          against official records at the time of publication. If you represent this clinic or practitioner and
          something is inaccurate or you'd like the listing updated or removed, email
          <a href="mailto:corrections@YOUR-DOMAIN.com">corrections@YOUR-DOMAIN.com</a> — we act on requests within 5 business days.
        </div>
      )}
    </main>
    <footer class="meta">
      <p>© {new Date().getFullYear()} Peptide Directory &amp; News. Listings are editorial; no clinic or doctor pays for placement.</p>
    </footer>
  </body>
</html>
