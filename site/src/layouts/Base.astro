---
import { SECTIONS, sectionHref, SITES } from '../lib/sections';

interface Props {
  title: string;
  description: string;
  jsonLd?: Record<string, unknown>;
  showCorrections?: boolean;
  image?: string;
  ogImage?: string;
  currentSection?: string;
}
const { title, description, jsonLd, showCorrections = false, image, ogImage, currentSection = 'Clinics' } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || SITES.clinics;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : image ? `${siteUrl}${image}` : null;
const correctionsEmail = import.meta.env.PUBLIC_CORRECTIONS_EMAIL;
const analyticsDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f7f9f6" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={Astro.url.href} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta property="og:site_name" content="Peptide Clinics Directory" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    {analyticsDomain && <script defer data-domain={analyticsDomain} src="https://plausible.io/js/script.js"></script>}
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('peptide-theme');
        const theme = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'lab' : 'clinical');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="header-inner">
        <a href={SITES.clinics} class="brand" aria-label="Peptide Atlas clinics home">
          <span class="brand-mark" aria-hidden="true">P</span>
          <span><strong>Peptide Atlas</strong><small>Verified clinics</small></span>
        </a>
        <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Open navigation" aria-expanded="false" aria-controls="site-nav"><span></span><span></span><span></span></button>
        <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
          {SECTIONS.map((section) => (
            <a href={sectionHref(section)} aria-current={section.label === currentSection ? 'page' : undefined}>{section.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main id="main-content" class="site-main">
      <div class="container"><slot /></div>
      <div class="container trust-footer">
        <div class="disclaimer"><strong>Medical disclaimer</strong><span>This content is for informational purposes only and is not medical advice, diagnosis, or treatment. Peptide therapies vary in regulatory status; several remain under FDA review. Always consult a licensed physician before starting any therapy.</span></div>
        {showCorrections && <div class="corrections"><strong>Corrections</strong><span>Information on this page was compiled from public sources and verified against official records at the time of publication. If something is inaccurate or should be updated or removed, {correctionsEmail ? <a href={`mailto:${correctionsEmail}`}>{correctionsEmail}</a> : <a href={`${SITES.content}/corrections/`}>use the corrections page</a>}. We act on requests within 5 business days.</span></div>}
      </div>
    </main>
    <footer class="site-footer"><div class="container footer-inner"><p><strong>Peptide Atlas</strong><br />Evidence-first directories and reporting.</p><nav class="footer-links" aria-label="Editorial information"><a href={`${SITES.content}/about/`}>About</a><a href={`${SITES.content}/editorial-policy/`}>Editorial policy</a><a href={`${SITES.content}/corrections/`}>Corrections</a></nav><p>© {new Date().getFullYear()} Peptide Clinics Directory.<br />No clinic pays for placement.</p></div></footer>
    <div class="theme-control">
      <div class="theme-menu" id="theme-menu" role="menu" aria-label="Choose a color theme" hidden>
        <button type="button" role="menuitemradio" data-theme-option="clinical"><span class="swatch swatch-clinical"></span><span><strong>Clinical</strong><small>Clean and calm</small></span></button>
        <button type="button" role="menuitemradio" data-theme-option="lab"><span class="swatch swatch-lab"></span><span><strong>Lab</strong><small>Dark and technical</small></span></button>
        <button type="button" role="menuitemradio" data-theme-option="wellness"><span class="swatch swatch-wellness"></span><span><strong>Wellness</strong><small>Warm and natural</small></span></button>
        <button type="button" role="menuitemradio" data-theme-option="editorial"><span class="swatch swatch-editorial"></span><span><strong>Editorial</strong><small>Paper and blue ink</small></span></button>
      </div>
      <button class="theme-trigger" id="theme-switcher" type="button" aria-label="Choose color theme" aria-haspopup="menu" aria-controls="theme-menu" aria-expanded="false"><span class="theme-dot"></span><span id="theme-label">Clinical</span><span class="theme-chevron" aria-hidden="true">⌃</span></button>
    </div>
    <script is:inline>
      (() => {
        const navButton = document.getElementById('nav-toggle');
        const nav = document.getElementById('site-nav');
        navButton?.addEventListener('click', () => {
          const open = nav?.classList.toggle('is-open') || false;
          navButton.setAttribute('aria-expanded', String(open));
          navButton.setAttribute('aria-label', open ? 'Close navigation' : 'Open navigation');
        });
        const labels = { clinical: 'Clinical', lab: 'Lab', wellness: 'Wellness', editorial: 'Editorial' };
        const button = document.getElementById('theme-switcher');
        const menu = document.getElementById('theme-menu');
        const label = document.getElementById('theme-label');
        const options = document.querySelectorAll('[data-theme-option]');
        const closeMenu = () => { if (menu) menu.hidden = true; button?.setAttribute('aria-expanded', 'false'); };
        const sync = (theme) => {
          document.documentElement.dataset.theme = theme;
          localStorage.setItem('peptide-theme', theme);
          if (label) label.textContent = labels[theme];
          options.forEach((option) => option.setAttribute('aria-checked', String(option.dataset.themeOption === theme)));
        };
        sync(document.documentElement.dataset.theme || 'clinical');
        button?.addEventListener('click', () => { if (menu) menu.hidden = !menu.hidden; button.setAttribute('aria-expanded', String(menu && !menu.hidden)); });
        options.forEach((option) => option.addEventListener('click', () => { sync(option.dataset.themeOption); closeMenu(); button?.focus(); }));
        document.addEventListener('click', (event) => { if (!event.target.closest('.theme-control')) closeMenu(); });
        document.addEventListener('keydown', (event) => { if (event.key === 'Escape') { closeMenu(); button?.focus(); } });
      })();
    </script>
  </body>
</html>
