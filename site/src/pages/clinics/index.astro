---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { stateName } from '../../lib/states';

const all = await getCollection('clinics');
const clinics = all.filter((p) => !p.id.startsWith('_sample'));

const totalClinics = clinics.length;
const states = [...new Set(clinics.map((p) => p.data.state))].sort();
const cities = [...new Set(clinics.map((p) => p.data.city))].sort();
const services = [...new Set(clinics.flatMap((p) => p.data.services))].sort();

const rated = clinics.filter((p) => p.data.ratingValue);
const avgRating = rated.length > 0
  ? (rated.reduce((sum, p) => sum + (p.data.ratingValue || 0), 0) / rated.length).toFixed(1)
  : null;
---
<Base title="Peptide Therapy Clinics Directory | Find Verified Clinics" description={`Browse ${totalClinics} verified peptide therapy clinics across ${states.length} US states. Filter by city, state, services, and ratings.`}>
  <section class="network-hero">
    <p class="eyebrow">Verified clinic research</p>
    <h1>Compare clinics with the facts in view.</h1>
    <p>Filter fact-checked listings by location, services, and attributed public ratings. No paid placements.</p>
  </section>

  {totalClinics === 0 ? (
    <div class="empty-state">
      <p>Clinics are being added city by city.</p>
      <p class="meta">Check back soon for verified listings.</p>
    </div>
  ) : (
    <>
      <p class="meta">
        {totalClinics} verified clinics · {states.length} states · {cities.length} cities
        {avgRating && ` · ${avgRating}★ average rating`}
      </p>

      <div class="directory-filters" id="clinic-filters">
        <input type="text" id="search-input" placeholder="Search clinics, cities, or services..." class="search-input" />
        <select id="state-filter" class="filter-select">
          <option value="">All States</option>
          {states.map((s) => <option value={s}>{stateName(s)}</option>)}
        </select>
        <select id="service-filter" class="filter-select">
          <option value="">All Services</option>
          {services.map((s) => <option value={s}>{s}</option>)}
        </select>
        <select id="rating-filter" class="filter-select">
          <option value="">Any Rating</option>
          <option value="4.5">4.5+ stars</option>
          <option value="4">4+ stars</option>
          <option value="3">3+ stars</option>
        </select>
        <button id="clear-filters" class="filter-btn">Clear</button>
      </div>

      <div class="directory-results" id="results-list" style="display: flex; flex-direction: column; gap: 0.75rem; margin: 1rem 0;">
        {clinics.map((p) => (
          <article class="directory-card" data-state={p.data.state} data-city={p.data.city.toLowerCase()} data-services={p.data.services.join('|').toLowerCase()} data-name={p.data.clinicName.toLowerCase()} data-rating={p.data.ratingValue || 0}>
            <div class="card-main">
              <h3><a href={`/clinics/${p.id}/`}>{p.data.clinicName}</a></h3>
              <p class="meta">{p.data.city}, {p.data.state}</p>
              {p.data.services.length > 0 && (
                <p class="services" style="margin: 0.4rem 0 0 0;">
                  {p.data.services.slice(0, 4).map((s) => (
                    <span class="tag">{s}</span>
                  ))}
                </p>
              )}
              {p.data.ratingValue && p.data.ratingSource && (
                <p class="rating-chip" style="margin-top: 0.3rem;">
                  {p.data.ratingValue}★ <span class="rating-source">({p.data.ratingCount} reviews on {p.data.ratingSource})</span>
                </p>
              )}
            </div>
            <a href={`/clinics/${p.id}/`} class="cta" style="font-size: var(--text-xs); padding: 0.4rem 0.8rem; white-space: nowrap; margin-left: 1rem;">View →</a>
          </article>
        ))}
      </div>

      <p class="meta" id="results-count">Showing {totalClinics} clinics</p>
    </>
  )}

  <script is:inline>
    (function() {
      var search = document.getElementById('search-input');
      var stateFilter = document.getElementById('state-filter');
      var serviceFilter = document.getElementById('service-filter');
      var ratingFilter = document.getElementById('rating-filter');
      var clearBtn = document.getElementById('clear-filters');
      var results = document.getElementById('results-list');
      var count = document.getElementById('results-count');
      var cards = results ? Array.from(results.querySelectorAll('.directory-card')) : [];
      var initialQuery = new URLSearchParams(window.location.search).get('q') || '';
      if (search && initialQuery) search.value = initialQuery;

      function filter() {
        var q = (search?.value || '').toLowerCase().trim();
        var state = stateFilter?.value || '';
        var service = (serviceFilter?.value || '').toLowerCase();
        var minRating = parseFloat(ratingFilter?.value || '0');

        var visible = 0;
        cards.forEach(function(card) {
          var name = card.dataset.name || '';
          var cardState = card.dataset.state || '';
          var city = card.dataset.city || '';
          var services = card.dataset.services || '';
          var rating = parseFloat(card.dataset.rating || '0');

          var matchesSearch = !q || name.includes(q) || city.includes(q) || services.includes(q);
          var matchesState = !state || cardState === state;
          var matchesService = !service || services.includes(service);
          var matchesRating = !minRating || rating >= minRating;

          if (matchesSearch && matchesState && matchesService && matchesRating) {
            card.style.display = 'flex';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });

        if (count) count.textContent = 'Showing ' + visible + ' clinic' + (visible !== 1 ? 's' : '');
      }

      search?.addEventListener('input', filter);
      stateFilter?.addEventListener('change', filter);
      serviceFilter?.addEventListener('change', filter);
      ratingFilter?.addEventListener('change', filter);
      clearBtn?.addEventListener('click', function() {
        if (search) search.value = '';
        if (stateFilter) stateFilter.value = '';
        if (serviceFilter) serviceFilter.value = '';
        if (ratingFilter) ratingFilter.value = '';
        filter();
      });
      filter();
    })();
  </script>
</Base>
