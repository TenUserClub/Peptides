---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { clinicsByState, stateName, stateSlug, HUB_MIN_CLINICS } from '../../../lib/states';

export async function getStaticPaths() {
  const all = await getCollection('clinics');
  return Object.entries(clinicsByState(all))
    .filter(([, posts]) => posts.length >= HUB_MIN_CLINICS)
    .map(([code, posts]) => ({ params: { state: stateSlug(code) }, props: { code, posts } }));
}

const { code, posts } = Astro.props;
const name = stateName(code);

const byCity: Record<string, typeof posts> = {};
for (const p of posts) (byCity[p.data.city] ??= []).push(p);
const cities = Object.keys(byCity).sort();
---
<Base
  title={`Peptide Clinics in ${name}: ${posts.length} Verified Listings | Peptide Clinics Directory`}
  description={`Browse ${posts.length} verified peptide therapy clinics across ${cities.length} ${cities.length === 1 ? 'city' : 'cities'} in ${name}, with services, practitioner details, and summarized public reviews.`}
>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="sep" aria-hidden="true">→</span>
    <a href="/clinics/">Clinics</a>
    <span class="sep" aria-hidden="true">→</span>
    <span aria-current="page">{name}</span>
  </nav>

  <h1>Peptide clinics in {name}</h1>
  <p class="meta">{posts.length} verified {posts.length === 1 ? 'listing' : 'listings'} · <a href="/clinics/">all states</a></p>

  {cities.map((city) => (
    <section>
      <h2>{city}</h2>
      <ul>
        {byCity[city]
          .sort((a, b) => a.data.clinicName.localeCompare(b.data.clinicName))
          .map((p) => (
            <li><a href={`/clinics/${p.id}/`}>{p.data.clinicName}</a>{p.data.services.length > 0 && ` — ${p.data.services.slice(0, 3).join(', ')}`}</li>
          ))}
      </ul>
    </section>
  ))}
</Base>
