---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

const allBlog = await getCollection('blog');
const related = allBlog
  .filter((p) => p.id !== post.id && p.data.category === d.category)
  .slice(0, 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: d.title,
  datePublished: d.publishDate.toISOString(),
  description: d.description,
  ...(d.image ? { image: `https://peptide-seo-site.vercel.app${d.image}` } : {}),
};
---
<Base
  title={d.title}
  description={d.description}
  jsonLd={jsonLd}
  image={d.image}
  ogImage={d.ogImage}
>
  <article>
    {d.image && (
      <div class="featured-image">
        <img src={d.image} alt={`Featured image for ${d.title}`} loading="eager" />
      </div>
    )}
    <p class="meta">
      <span style="text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em;">{d.category}</span>
      · Published {d.publishDate.toISOString().slice(0, 10)}
      {d.updatedDate && ` · Updated ${d.updatedDate.toISOString().slice(0, 10)}`}
    </p>
    <h1>{d.title}</h1>
    <Content />

    {related.length > 0 && (
      <section style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--rule, #e6e4dc);">
        <h2>Related guides</h2>
        <ul>
          {related.map((p) => (
            <li><a href={`/blog/${p.id}/`}>{p.data.title}</a></li>
          ))}
        </ul>
      </section>
    )}
  </article>
</Base>
