---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('legal');
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  datePublished: d.publishDate.toISOString(),
  ...(d.updatedDate ? { dateModified: d.updatedDate.toISOString() } : {}),
  description: d.description,
};

const recent = (await getCollection('legal'))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => +b.data.publishDate - +a.data.publishDate)
  .slice(0, 5);
---
<Base title={d.title} description={d.description} jsonLd={jsonLd}>
  <article>
    <h1>{d.title}</h1>
    <p class="meta">
      {d.jurisdiction} · {d.publishDate.toISOString().slice(0, 10)}
      {d.updatedDate && ` · Updated ${d.updatedDate.toISOString().slice(0, 10)}`}
      · Reporting based on <a href={d.sourceUrl} rel="nofollow">{d.sourceName}</a>
    </p>
    <Content />
    <p class="meta">This article is general information about laws and regulation, not legal advice. For decisions about a specific situation, consult a licensed attorney.</p>
    {recent.length > 0 && (
      <section>
        <h2>More laws &amp; legal coverage</h2>
        <ul>{recent.map((p) => (<li><a href={`/legal/${p.id}/`}>{p.data.title}</a></li>))}</ul>
      </section>
    )}
  </article>
</Base>
