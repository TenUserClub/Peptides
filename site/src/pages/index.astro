---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { stateName } from '../lib/states';

const clinics = (await getCollection('clinics')).filter((p) => !p.id.startsWith('_sample'));
const totalClinics = clinics.length;
const states = [...new Set(clinics.map((p) => p.data.state))].sort();
const cities = [...new Set(clinics.map((p) => p.data.city))].sort();
const recent = clinics.sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 6);
---
<Base title="Peptide Clinics Directory | Find Verified Peptide Therapy Clinics" description={`Browse ${totalClinics} verified peptide therapy clinics across ${states.length} US states. Filter by city, state, and services.`}>
  <div class="hero">
    <h1>Find verified peptide therapy clinics</h1>
    <p>Browse verified clinics offering peptide therapy, GLP-1 treatments, hormone optimization, and longevity medicine across the United States.</p>
    <a class="cta" href="/clinics/" style="margin-top: var(--space-lg);">Browse all clinics →</a>
  </div>

  <div class="stats-grid">
    <div class="stat-item">
      <div class="stat-value">{totalClinics}</div>
      <div class="stat-label">Verified Clinics</div>
    </div>
    <div class="stat-item">
      <div class="stat-value">{states.length}</div>
      <div class="stat-label">States</div>
    </div>
    <div class="stat-item">
      <div class="stat-value">{cities.length}</div>
      <div class="stat-label">Cities</div>
    </div>
  </div>

  {states.length > 0 && (
    <>
      <h2>Browse by state</h2>
      <div class="state-grid">
        {states.map((s) => (
          <a href={`/clinics/${stateName(s).toLowerCase().replace(/\s+/g, '-')}/`} class="state-link">{stateName(s)}</a>
        ))}
      </div>
    </>
  )}

  {recent.length > 0 && (
    <>
      <h2>Recently added clinics</h2>
      <div class="card-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem; margin-bottom: 1.5rem;">
        {recent.map((p) => (
          <article class="card">
            {p.data.image && <img class="card-image" src={p.data.image} alt="" loading="lazy" />}
            <div class="card-body">
              <h3><a href={`/clinics/${p.id}/`}>{p.data.title}</a></h3>
              <p class="meta">{p.data.city}, {p.data.state}</p>
              {p.data.services.length > 0 && (
                <p class="services" style="margin: 0.3rem 0 0 0;">
                  {p.data.services.slice(0, 2).map((s) => (
                    <span class="tag">{s}</span>
                  ))}
                </p>
              )}
            </div>
          </article>
        ))}
      </div>
      <p><a href="/clinics/">View all clinics →</a></p>
    </>
  )}
</Base>
