---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { stateName } from '../lib/states';

const clinics = (await getCollection('clinics')).filter((item) => !item.id.startsWith('_sample'));
const totalClinics = clinics.length;
const states = [...new Set(clinics.map((item) => item.data.state))].sort();
const cities = [...new Set(clinics.map((item) => item.data.city))].sort();
const recent = [...clinics].sort((a, b) => +b.data.publishDate - +a.data.publishDate).slice(0, 6);
---
<Base title="Peptide Clinics Directory | My Peptide Club" description={`Research ${totalClinics} checked peptide clinic listings across ${states.length} US states, with visible sources and correction routes.`}>
  <section class="network-hero hero-centered">
    <p class="eyebrow">Independent US clinic registry</p>
    <h1>Find a peptide clinic you can actually research.</h1>
    <p>Search public clinic information, documented services, and last-checked details. Every published listing points back to a first-party source.</p>
    <form class="hero-search" action="/clinics/" method="get">
      <input name="q" type="search" aria-label="Search clinics" placeholder="Clinic, city, state, or service" />
      <button class="cta" type="submit">Search the registry</button>
    </form>
    <div class="hero-chips" aria-label="Popular clinic searches"><a class="hero-chip" href="/clinics/?q=peptide">Peptide therapy</a><a class="hero-chip" href="/clinics/?q=GLP-1">GLP-1 care</a><a class="hero-chip" href="/clinics/?q=longevity">Longevity medicine</a><a class="hero-chip" href="/faq/">How verification works</a></div>
  </section>

  <div class="info-strip" aria-label="Registry status">
    <div><strong>{totalClinics} clinic listings</strong><span>Published only after a first-party source check</span></div>
    <div><strong>{states.length} states covered</strong><span>Browse location pages without paid placement</span></div>
    <div><strong>{cities.length} cities indexed</strong><span>Details stay tied to their verification dates</span></div>
  </div>

  <div class="section-kicker"><div><p class="eyebrow">Clinic research</p><h2>Start with place, then verify the details.</h2></div><p>The registry organizes public information. It does not rank providers or decide whether a treatment is appropriate.</p></div>

  {totalClinics === 0 ? <section class="empty-state"><p class="eyebrow">Verification queue</p><h2>The first clinic records are being checked.</h2><p>Listings will appear after the clinic website, location, and stated services pass review. The directory remains searchable as soon as the first record is ready.</p><a class="text-link" href="/faq/">Read the clinic directory FAQ</a></section> : <div class="card-grid">
    {recent.map((item) => <article class="card"><div class="card-body"><span class="verified-badge">Checked listing</span><h3><a href={`/clinics/${item.id}/`}>{item.data.title}</a></h3><p class="meta">{item.data.city}, {item.data.state}</p><div class="hero-chips service-chips">{item.data.services.slice(0, 3).map((service) => <span class="hero-chip service-chip">{service}</span>)}</div></div></article>)}
  </div>}

  {states.length > 0 && <section><div class="section-kicker"><div><p class="eyebrow">Browse the registry</p><h2>Clinics by state</h2></div><a class="text-link" href="/clinics/">View every listing</a></div><div class="state-grid">{states.map((state) => <a class="state-link" href={`/clinics/${stateName(state).toLowerCase().replace(/\s+/g, '-')}/`}>{stateName(state)}</a>)}</div></section>}

  <section class="faq-preview"><div><p class="eyebrow">100 focused clinic answers</p><h2>Before you contact a clinic, know what to check.</h2><p>Understand listings, services, appointments, costs, regulation, reviews, privacy, and corrections.</p></div><a class="cta" href="/faq/">Open the clinic FAQ</a></section>
</Base>
