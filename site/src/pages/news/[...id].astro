---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: d.title,
  datePublished: d.publishDate.toISOString(),
  description: d.description,
};
---
<Base title={d.title} description={d.description} jsonLd={jsonLd}>
  <article>
    <h1>{d.title}</h1>
    <p class="meta">{d.publishDate.toISOString().slice(0, 10)} · Reporting based on <a href={d.sourceUrl} rel="nofollow">{d.sourceName}</a></p>
    <Content />
  </article>
</Base>
